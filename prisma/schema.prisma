// MyDashboard data model. Multi-tenant by owner: a User sees only the Clients
// they own (cloisonné). Local dev = SQLite; prod = Postgres (flip provider).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  // Login identifier. Nullable only so `db push` can add it to a populated
  // table; the seed backfills it from `email` on first boot and the app treats
  // it as required from then on.
  username     String?  @unique
  // Contact address, optional: it is no longer the credential.
  email        String?  @unique
  name         String?
  passwordHash String
  // SUPER_ADMIN sees everything · ADMIN owns their own clients and invites
  // members onto them · MEMBER only sees clients they were invited to.
  role         String   @default("MEMBER") // SUPER_ADMIN | ADMIN | MEMBER
  mustChangePassword Boolean @default(false) // force a password change on first login
  createdAt    DateTime @default(now())
  agencyName   String?
  agencyLogo   String?
  footerNote   String?
  clients      Client[]
  connections  Connection[]
  assignments  ClientAssignment[]
}

model Client {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name       String
  sector     String?
  brandColor String   @default("#4f46e5")
  logoUrl    String?
  createdAt  DateTime @default(now())
  reports    Report[]
  sources    ClientSource[]
  // Members invited onto this client by its owner. Purely additive: ownerId is
  // never rewritten, so revoking an invitation can't orphan a client.
  assignments ClientAssignment[]
}

// "User X may work on client Y". A client with no assignments is private to
// its owner — which is what makes an admin's own clients invisible to the
// other admins without needing a visibility flag.
model ClientAssignment {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([clientId, userId])
  @@index([userId])
}

model Report {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title        String   @default("Rapport de performance")
  periodLabel  String?
  compareLabel String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  widgets      Widget[]
  shareLinks   ShareLink[]
}

// Public read-only access to a report (the DashThis-style client link).
// Token is unguessable (32 hex chars); revoking = deleting the row.
model ShareLink {
  id        String   @id @default(cuid())
  token     String   @unique
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Widget {
  id        String  @id @default(cuid())
  reportId  String
  report    Report  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  type      String // kpi | line | donut | bar | table | content | illustration
  title     String?
  sourceKey String? // matomo | ga4 | facebook | instagram | linkedin | gmb | manual
  span      Int     @default(12) // grid columns 1..12
  position  Int     @default(0)
  config    Json? // widget settings (metric ids, labels, html, etc.)
}

model Connection {
  id           String    @id @default(cuid())
  ownerId      String
  owner        User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  provider     String // matomo | ga4 | meta | gmb | linkedin
  authType     String // oauth | token
  status       String    @default("connected") // connected | error
  accountLabel String?
  accessToken  String? // encrypted at rest
  refreshToken String? // encrypted at rest
  expiresAt    DateTime?
  meta         Json? // non-secret provider config (e.g. matomo url)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  clientSources ClientSource[]

  @@unique([ownerId, provider])
}

model ClientSource {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  provider   String // matomo | ga4 | meta | gmb | linkedin
  externalId String // GA4 property id, FB page id, Matomo site id, etc.
  label      String?
  // Which connection this id belongs to. An externalId is only meaningful
  // against the instance it came from (Matomo site "7" means nothing on
  // another server), so the binding records it explicitly.
  connectionId String?
  connection   Connection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@unique([clientId, provider])
}
